# Copy this file to .env.local and fill in your values.

# Mapy.com API key — server-side only, used by the /api/geocode proxy route.
# Get a key at https://developer.mapy.com
MAP_API_KEY=your_key_here

# Mapy.com API key — exposed to the browser, used for map tile URLs in FirmaMap.
# Set a domain restriction in the Mapy.com developer portal (localhost + prod domain).
# Can be the same key as MAP_API_KEY (Get a key at https://developer.mapy.com) if domain-restricted and secured as Maps.com say in their API docs.
NEXT_PUBLIC_MAP_API_KEY=your_key_here
